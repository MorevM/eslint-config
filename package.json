{
	"name": "@morev/eslint-config",
	"description": "Strict shareable ESLint configuration with reasonable defaults",
	"type": "module",
	"version": "42.0.0-rc.3",
	"engines": {
		"node": ">=22.22.3"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"author": {
		"name": "Maxim Morev",
		"email": "max.seainside@gmail.com"
	},
	"homepage": "https://github.com/MorevM/eslint-config#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/MorevM/eslint-config"
	},
	"keywords": [
		"eslint",
		"eslintconfig",
		"config",
		"codestyle"
	],
	"files": [
		"dist",
		"bin"
	],
	"bin": "./bin/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./globs": {
			"types": "./dist/globs.d.mts",
			"import": "./dist/globs.mjs"
		},
		"./parsers": {
			"types": "./dist/parsers.d.mts",
			"import": "./dist/parsers.mjs"
		},
		"./plugins": {
			"types": "./dist/plugins.d.mts",
			"import": "./dist/plugins.mjs"
		}
	},
	"main": "./dist/index.mjs",
	"scripts": {
		"prepare": "lefthook install",
		"build": "tsdown",
		"test": "pnpm build && vitest",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"release": "release-it --disable-metrics",
		"release:rc": "release-it --preRelease=rc --disable-metrics"
	},
	"peerDependencies": {
		"eslint": "^10.4.0",
		"typescript": ">=5.4.2"
	},
	"dependencies": {
		"@clack/prompts": "^1.6.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@eslint/markdown": "^8.0.3",
		"@html-eslint/eslint-plugin": "^0.63.0",
		"@html-eslint/parser": "^0.63.0",
		"@morev/eslint-disable-autofix": "^1.1.0",
		"@morev/utils": "^3.15.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@vitest/eslint-plugin": "^1.6.20",
		"ansis": "^4.3.1",
		"astro-eslint-parser": "^2.1.0",
		"eslint-config-flat-gitignore": "^2.3.0",
		"eslint-import-resolver-typescript": "^4.4.5",
		"eslint-plugin-astro": "^2.1.1",
		"eslint-plugin-chai-friendly": "^1.2.1",
		"eslint-plugin-command": "^3.5.2",
		"eslint-plugin-cypress": "^6.4.1",
		"eslint-plugin-import-x": "^4.17.0",
		"eslint-plugin-jest": "^29.15.3",
		"eslint-plugin-jsdoc": "^63.0.10",
		"eslint-plugin-jsonc": "^3.2.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-markdown-preferences": "^0.41.1",
		"eslint-plugin-n": "^18.2.1",
		"eslint-plugin-no-secrets": "^2.3.3",
		"eslint-plugin-package-json": "^1.5.0",
		"eslint-plugin-perfectionist": "^5.9.1",
		"eslint-plugin-playwright": "^2.10.4",
		"eslint-plugin-regexp": "^3.1.1",
		"eslint-plugin-sonarjs": "^1.0.4",
		"eslint-plugin-unicorn": "^69.0.0",
		"eslint-plugin-vue": "^10.9.2",
		"eslint-plugin-yml": "^3.5.0",
		"eslint-rule-composer": "^0.3.0",
		"globals": "^17.7.0",
		"jsonc-eslint-parser": "^3.1.0",
		"jsonc-parser": "^3.3.1",
		"package-manager-detector": "^1.6.0",
		"semver": "^7.8.5",
		"typescript-eslint": "^8.62.0",
		"vue-eslint-parser": "^10.4.1",
		"yaml-eslint-parser": "^2.0.0"
	},
	"devDependencies": {
		"@morev/commitlint-config": "^0.2.2",
		"@morev/eslint-config": "workspace:^",
		"@release-it/conventional-changelog": "8.0.2",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^22.18.10",
		"@types/semver": "^7.7.1",
		"eslint": "^10.6.0",
		"jiti": "^2.7.0",
		"lefthook": "^2.1.9",
		"release-it": "^20.2.1",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite-tsconfig-paths": "^6.1.1",
		"vitest": "^4.1.9",
		"vue": "^3.5.39"
	}
}
